<Application x:Class="ParisSportif.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <!-- Couleurs -->
    <Color x:Key="PrimaryColor">#E74C3C</Color>
    <Color x:Key="PrimaryDark">#C0392B</Color>
    <Color x:Key="LiveColor">#E74C3C</Color>
    <Color x:Key="BgColor">#F5F7FA</Color>
    <Color x:Key="TextColor">#2C3E50</Color>
    <Color x:Key="MutedColor">#7F8C94</Color>

    <SolidColorBrush x:Key="PrimaryBrush"   Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="LiveBrush"      Color="{StaticResource LiveColor}"/>
    <SolidColorBrush x:Key="BgBrush"        Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="TextBrush"      Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="MutedBrush"     Color="{StaticResource MutedColor}"/>

    <!-- Style bouton principal -->
    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Padding" Value="12,7"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Style bouton secondaire -->
    <Style x:Key="BtnSecondary" TargetType="Button">
      <Setter Property="Background" Value="#E0E6ED"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#C8D6E5"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Style bouton LIVE / cashout -->
    <Style x:Key="BtnLive" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="8,5"/>
    </Style>

  </Application.Resources>
</Application>
