<Window x:Class="ParisSportif.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ParisSportif — Analyse Live"
        WindowState="Maximized"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>     <!-- TabControl plein écran -->
      <RowDefinition Height="Auto"/>  <!-- Barre de statut -->
    </Grid.RowDefinitions>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  TabControl principal (onglets statiques + dynamiques)          -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <TabControl Grid.Row="0" x:Name="MainTabs" Background="White">

      <!-- ── Onglet 0 : ParionsSport ─────────────────────────────── -->
      <TabItem Header="🎯 ParionsSport">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal"
                      Margin="8,6" Background="White">
            <Button Content="🔄 Extraire mes paris"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnExtraire_Click"
                    Margin="0,0,12,0"
                    ToolTip="Injecte le script extracteur sur la page actuelle"/>
            <Button Content="🐛 Debug HTML"
                    Style="{StaticResource BtnSecondary}"
                    Click="BtnDebugHtml_Click"
                    Margin="0,0,12,0"
                    ToolTip="Sauvegarde le HTML de la page dans un fichier pour diagnostic"/>
            <TextBlock VerticalAlignment="Center" FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       Text="💡 Connecte-toi, navigue vers tes paris ou une page de cotes, puis clique Extraire"/>
          </StackPanel>

          <wv2:WebView2 x:Name="WebViewPS" Grid.Row="1"/>
        </Grid>
      </TabItem>

      <!-- ── Onglet 1 : Paris extraits (s'active automatiquement) ── -->
      <TabItem x:Name="TabParis" Header="📊 Paris extraits">
        <Grid>
          <!-- DataGrid — 8 colonnes visibles avec wrap multi-lignes -->
          <DataGrid
                    x:Name="PariGrid"
                    ItemsSource="{Binding Paris}"
                    SelectedItem="{Binding SelectedPari}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    SelectionMode="Single"
                    BorderThickness="0"
                    Background="White"
                    RowBackground="White"
                    AlternatingRowBackground="#FAFBFC"
                    CanUserResizeRows="True"
                    CanUserResizeColumns="True"
                    CanUserReorderColumns="False"
                    FontSize="13">

            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLive}" Value="True">
                    <Setter Property="Background" Value="#FFF5F5"/>
                    <Setter Property="BorderBrush" Value="#E74C3C"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

              <!-- ① Sport : emoji + statut -->
              <DataGridTemplateColumn Header="Sport" Width="Auto" MinWidth="65" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="4,6">
                      <TextBlock Text="{Binding SportEmoji}" FontSize="22"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding StatutLabel}" FontSize="10"
                                 HorizontalAlignment="Center"
                                 Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- ② Date et Heure -->
              <DataGridTemplateColumn Header="Date / Heure" Width="Auto" MinWidth="85" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel VerticalAlignment="Center" Margin="6,4">
                      <TextBlock Text="{Binding DatePari}" FontSize="11"
                                 TextWrapping="Wrap"
                                 Foreground="{StaticResource MutedBrush}"/>
                      <TextBlock Text="{Binding MinuteOuHeure}" FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- ③ Match / Compétition / Sélection — prend tout l'espace restant -->
              <DataGridTemplateColumn Header="Match / Sélection" Width="*" MinWidth="180" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel VerticalAlignment="Center" Margin="8,4">
                      <TextBlock Text="{Binding MatchLabel}"
                                 FontWeight="SemiBold" FontSize="14"
                                 TextWrapping="Wrap"
                                 Foreground="{StaticResource TextBrush}"/>
                      <TextBlock Text="{Binding Marche}" FontSize="11"
                                 TextWrapping="Wrap"
                                 Foreground="{StaticResource MutedBrush}"/>
                      <TextBlock Text="{Binding Selection}" FontSize="12"
                                 TextWrapping="Wrap"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Margin="0,2,0,0"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- ④ Cote(s) -->
              <DataGridTextColumn Header="Cote(s)" Width="Auto" MinWidth="80"
                                  Binding="{Binding Cote}"
                                  CanUserSort="False">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="8,4"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- ⑤ Proba implicite cote -->
              <DataGridTextColumn Header="Proba implicite" Width="Auto" MinWidth="100"
                                  Binding="{Binding ProbabiliteImpliciteLabel}"
                                  CanUserSort="False">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="8,4"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- ⑥ % Paris parieurs -->
              <DataGridTextColumn Header="% Paris" Width="Auto" MinWidth="100"
                                  Binding="{Binding RepartitionLabel}"
                                  SortMemberPath="AnomalieMax"
                                  CanUserSort="True">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="8,4"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- ⑦ Indicateur paris/cote — anomalie, triable, coloré -->
              <DataGridTemplateColumn Header="⚡ Indicateur" Width="Auto" MinWidth="120"
                                      SortMemberPath="AnomalieMax"
                                      CanUserSort="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Border CornerRadius="5" Margin="5,3" Padding="6,4">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding AnomalieNiveau}" Value="3">
                              <Setter Property="Background" Value="#FDEEEE"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding AnomalieNiveau}" Value="2">
                              <Setter Property="Background" Value="#FEF5EC"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding AnomalieNiveau}" Value="1">
                              <Setter Property="Background" Value="#FEFCE8"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding AnomalieLabelMax}"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AnomalieNiveau}" Value="3">
                                  <Setter Property="Foreground" Value="#C0392B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AnomalieNiveau}" Value="2">
                                  <Setter Property="Foreground" Value="#D35400"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AnomalieNiveau}" Value="1">
                                  <Setter Property="Foreground" Value="#A0760A"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding AnomalieDetail}"
                                   FontSize="10" FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AnomalieNiveau}" Value="3">
                                  <Setter Property="Foreground" Value="#C0392B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AnomalieNiveau}" Value="2">
                                  <Setter Property="Foreground" Value="#D35400"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AnomalieNiveau}" Value="1">
                                  <Setter Property="Foreground" Value="#A0760A"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- ⑧ Actions -->
              <DataGridTemplateColumn Header="Actions" Width="Auto" MinWidth="130" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Vertical" Margin="6,4"
                                VerticalAlignment="Center">
                      <Button Content="📄 Complet"
                              Style="{StaticResource BtnPrimary}"
                              FontSize="12" Padding="8,5"
                              Tag="{Binding}"
                              Click="BtnPromptComplet_Click"
                              Visibility="Collapsed"
                              ToolTip="Prompt complet autonome — données + protocole intégré"/>
                      <Button Content="🔬 Agent"
                              Style="{StaticResource BtnSecondary}"
                              FontSize="12" Padding="8,5"
                              Margin="0,4,0,0"
                              Tag="{Binding}"
                              Click="BtnPromptAgent_Click"
                              Visibility="Collapsed"
                              ToolTip="Prompt 2 phases : collecte structurée + analyse mathématique (~120 lignes)"/>
                      <Button Content="🦣 Mamouth"
                              Style="{StaticResource BtnSecondary}"
                              FontSize="12" Padding="8,5"
                              Margin="0,4,0,0"
                              Tag="{Binding}"
                              Click="BtnPromptMamouth_Click"
                              ToolTip="Prompt 2 phases optimisé (&lt;800 mots/phase) — copie Phase 1 puis Phase 2"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- ── Onglet DeepSeek ──────────────────────────────────────────── -->
      <TabItem x:Name="TabDeepSeek" Header="🤖 DeepSeek" Visibility="Collapsed">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal"
                      Margin="8,6" Background="White">
            <Button Content="📋 Coller le prompt"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnCollerDeepSeek_Click"
                    Margin="0,0,12,0"
                    ToolTip="Colle le contenu du presse-papier dans le chat DeepSeek"/>
            <Button Content="🔄 Chercher d'autres sources (phase 2)"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnAutresSourcesDeepSeek_Click"
                    Margin="0,0,12,0"
                    ToolTip="Injecte un prompt pour chercher d'autres sources et relancer la phase 2"/>
<Button Content="🌐 Tips Scanner"
                    Style="{StaticResource BtnSecondary}"
                    Click="BtnTipsScannerDeepSeek_Click"
                    Margin="0,0,4,0"
                    ToolTip="Scanne le web et les réseaux sociaux pour collecter tous les tips de paris disponibles"/>
            <Button Content="🔄 + Tips"
                    Style="{StaticResource BtnSecondary}"
                    Click="BtnTipsContinueDeepSeek_Click"
                    Margin="0,0,12,0"
                    ToolTip="Continue la recherche de tips et reconstruit le tableau complet (à utiliser dans le même thread)"/>
            <TextBlock VerticalAlignment="Center" FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       Text="💡 Active 🔍 Search dans DeepSeek avant de coller pour les cotes en temps réel"/>
          </StackPanel>

          <wv2:WebView2 x:Name="WebViewDS" Grid.Row="1"/>
        </Grid>
      </TabItem>

      <!-- ── Onglet Mamouth ────────────────────────────────────────────── -->
      <TabItem x:Name="TabMamouth" Header="🦣 Mamouth">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal"
                      Margin="8,6" Background="White">
            <Button Content="📋 Coller Phase 1"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnCollerP1Mamouth_Click"
                    Margin="0,0,8,0"
                    ToolTip="Colle la Phase 1 (collecte) dans le chat Mamouth"/>
            <Button Content="📋 Coller Phase 2"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnCollerP2Mamouth_Click"
                    Margin="0,0,8,0"
                    ToolTip="Colle la Phase 2 (analyse) dans le chat Mamouth — après la réponse Phase 1"/>
            <Button Content="🔄 Consolider"
                    Style="{StaticResource BtnSecondary}"
                    Click="BtnConsoliderMamouth_Click"
                    Margin="0,0,12,0"
                    ToolTip="Injecte un prompt pour consolider les données manquantes et améliorer la confiance"/>
            <TextBlock x:Name="MamouthMatchLabel"
                       VerticalAlignment="Center" FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       Text="💡 Clique 🦣 Mamouth sur un pari pour commencer"/>
          </StackPanel>

          <wv2:WebView2 x:Name="WebViewMM" Grid.Row="1"/>
        </Grid>
      </TabItem>

      <!-- Les onglets Analyse sont ajoutés dynamiquement par code-behind -->

    </TabControl>

    <!-- ── Barre de statut ─────────────────────────────────────────────── -->
    <Border Grid.Row="1" Background="#2C3E50" Padding="12,5">
      <TextBlock Text="{Binding StatusLog}"
                 Foreground="#CDD6F4" FontSize="11"
                 FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
    </Border>

  </Grid>
</Window>
