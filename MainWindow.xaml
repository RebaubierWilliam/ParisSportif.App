<Window x:Class="ParisSportif.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ParisSportif — Analyse Live"
        WindowState="Maximized"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>     <!-- TabControl plein écran -->
      <RowDefinition Height="Auto"/>  <!-- Barre de statut -->
    </Grid.RowDefinitions>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  TabControl principal (onglets statiques + dynamiques)          -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <TabControl Grid.Row="0" x:Name="MainTabs" Background="White">

      <!-- ── Onglet 0 : ParionsSport ─────────────────────────────── -->
      <TabItem Header="🎯 ParionsSport">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal"
                      Margin="8,6" Background="White">
            <Button Content="🔄 Extraire mes paris"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnExtraire_Click"
                    Margin="0,0,12,0"
                    ToolTip="Injecte le script extracteur sur la page actuelle"/>
            <TextBlock VerticalAlignment="Center" FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       Text="💡 Connecte-toi, navigue vers tes paris ou une page de cotes, puis clique Extraire"/>
          </StackPanel>

          <wv2:WebView2 x:Name="WebViewPS" Grid.Row="1"/>
        </Grid>
      </TabItem>

      <!-- ── Onglet 1 : Paris extraits (s'active automatiquement) ── -->
      <TabItem x:Name="TabParis" Header="📊 Paris extraits">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Barre d'info -->
          <Border Grid.Row="0" Background="#F8F9FA"
                  BorderBrush="#E0E6ED" BorderThickness="0,0,0,1"
                  Padding="12,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock VerticalAlignment="Center" Margin="0,0,20,0"
                         FontWeight="SemiBold" Foreground="{StaticResource TextBrush}">
                <Run Text="📋 Paris : "/>
                <Run Text="{Binding TotalParis, Mode=OneWay}" FontWeight="Bold"
                     Foreground="{StaticResource PrimaryBrush}"/>
                <Run Text=" | 🔴 Live : "/>
                <Run Text="{Binding LiveCount, Mode=OneWay}" FontWeight="Bold"
                     Foreground="{StaticResource LiveBrush}"/>
              </TextBlock>
              <CheckBox Content="🔴 Live seulement" VerticalAlignment="Center"
                        IsChecked="{Binding ShowLiveOnly}" FontSize="12"
                        Margin="0,0,16,0"/>
              <Button Content="🔍 Scan Value bookmakers"
                      Style="{StaticResource BtnPrimary}"
                      Click="BtnScanValue_Click"
                      FontSize="12" Padding="12,5"
                      Margin="0,0,8,0"
                      ToolTip="Génère un prompt comparant tes cotes avec Pinnacle, Betclic, Winamax, Bet365 pour détecter les value bets"/>
              <Button Content="📋 Instructions Projet"
                      Style="{StaticResource BtnSecondary}"
                      Click="BtnSystemPrompt_Click"
                      FontSize="12" Padding="12,5"
                      Margin="0,0,8,0"
                      ToolTip="Copie les protocoles d'analyse — à coller dans les instructions de ton Projet claude.ai (system prompt caché = économie de tokens)"/>
            </StackPanel>
          </Border>

          <!-- DataGrid grande hauteur de ligne -->
          <DataGrid Grid.Row="1"
                    x:Name="PariGrid"
                    ItemsSource="{Binding Paris}"
                    SelectedItem="{Binding SelectedPari}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    RowHeight="48"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    SelectionMode="Single"
                    BorderThickness="0"
                    Background="White"
                    RowBackground="White"
                    AlternatingRowBackground="#FAFBFC"
                    CanUserResizeRows="False"
                    CanUserReorderColumns="False"
                    FontSize="14">

            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLive}" Value="True">
                    <Setter Property="Background" Value="#FFF5F5"/>
                    <Setter Property="BorderBrush" Value="#E74C3C"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

              <!-- Statut -->
              <DataGridTextColumn Header="Statut" Width="90"
                                  Binding="{Binding StatutLabel}">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Sport -->
              <DataGridTextColumn Header="Sport" Width="60"
                                  Binding="{Binding SportEmoji}">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="FontSize" Value="22"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Match -->
              <DataGridTextColumn Header="Match" Width="*"
                                  Binding="{Binding MatchLabel}">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="FontSize" Value="15"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Compétition -->
              <DataGridTextColumn Header="Compétition" Width="150"
                                  Binding="{Binding Marche}">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Sélection -->
              <DataGridTextColumn Header="Sélection" Width="200"
                                  Binding="{Binding Selection}">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Cote(s) -->
              <DataGridTextColumn Header="Cote(s)" Width="180"
                                  Binding="{Binding Cote}">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Heure -->
              <DataGridTextColumn Header="Heure" Width="70"
                                  Binding="{Binding MinuteOuHeure}">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Action -->
              <DataGridTemplateColumn Header="Action" Width="110">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="6,0"
                                VerticalAlignment="Center">
                      <Button Content="📋 Prompt"
                              Style="{StaticResource BtnSecondary}"
                              FontSize="12" Padding="10,5"
                              Tag="{Binding}"
                              Click="BtnPrompt_Click"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- ── Onglet DeepSeek ──────────────────────────────────────────── -->
      <TabItem x:Name="TabDeepSeek" Header="🤖 DeepSeek">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal"
                      Margin="8,6" Background="White">
            <Button Content="📋 Coller le prompt"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnCollerDeepSeek_Click"
                    Margin="0,0,12,0"
                    ToolTip="Colle le contenu du presse-papier dans le chat DeepSeek"/>
            <TextBlock VerticalAlignment="Center" FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       Text="💡 Active 🔍 Search dans DeepSeek avant de coller pour les cotes en temps réel"/>
          </StackPanel>

          <wv2:WebView2 x:Name="WebViewDS" Grid.Row="1"/>
        </Grid>
      </TabItem>

      <!-- Les onglets Analyse sont ajoutés dynamiquement par code-behind -->

    </TabControl>

    <!-- ── Barre de statut ─────────────────────────────────────────────── -->
    <Border Grid.Row="1" Background="#2C3E50" Padding="12,5">
      <TextBlock Text="{Binding StatusLog}"
                 Foreground="#CDD6F4" FontSize="11"
                 FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
    </Border>

  </Grid>
</Window>
